{
    "mcpServers": {
        "ollama-local": {
            "command": "python",
            "args": [
                "-m",
                "antigravity.mcp.ollama_server"
            ],
            "env": {
                "OLLAMA_HOST": "http://localhost:11434",
                "OLLAMA_MODELS": "smollm2:1.7b,qwen2.5:3b-instruct"
            },
            "disabled": false,
            "autoApprove": [
                "list_models",
                "generate_text",
                "classify_task"
            ]
        },
        "antigravity-core": {
            "command": "python",
            "args": [
                "-m",
                "antigravity.mcp.core_server"
            ],
            "env": {
                "ANTIGRAVITY_DIR": "C:/Users/<YOUR_USERNAME>/.gemini/antigravity",
                "GOOGLE_API_KEY": "<YOUR_GOOGLE_API_KEY>"
            },
            "disabled": false,
            "autoApprove": [
                "analyze_code",
                "route_task",
                "check_budget",
                "get_skills"
            ]
        },
        "filesystem": {
            "command": "python",
            "args": [
                "-m",
                "antigravity.mcp.filesystem_server"
            ],
            "env": {
                "ALLOWED_PATHS": "C:/Users/<YOUR_USERNAME>/.gemini"
            },
            "disabled": false,
            "autoApprove": [
                "read_file",
                "list_directory"
            ]
        }
    }
}